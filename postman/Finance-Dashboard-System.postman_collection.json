        {
          "name": "Login Admin (save token)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.token) {",
                  "  pm.environment.set('adminToken', json.data.token);",
                  "}"
